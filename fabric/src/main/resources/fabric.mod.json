{
  "schemaVersion": 1,
  "id": "${id}",
  "version": "${version}",
  "name": "${name}",
  "description": "Touhou Project music player for Minecraft",
  "authors": [
    "KabanFriends"
  ],
  "contributors": [],
  "contact": {
    "homepage": "https://modrinth.com/mod/craftgr",
    "sources": "https://github.com/KabanFriends/CraftGR",
    "issues": "https://github.com/KabanFriends/CraftGR/issues"
  },
  "environment": "client",
  "license": "LGPL-3.0",
  "icon": "icon.png",
  "entrypoints": {
    "modmenu": [
      "io.github.kabanfriends.craftgr.fabric.ModMenuIntegration"
    ],
    "client": [
      "io.github.kabanfriends.craftgr.fabric.CraftGRFabric"
    ],
    "server": []
  },
  "mixins": [
    "craftgr-common.mixins.json"
  ],
  "accessWidener": "craftgr.accesswidener",
  "depends": {
    "minecraft": ">=${minecraft_version}",
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-key-mapping-api-v1": "*",
    "fabric-lifecycle-events-v1": "*",
    "fabric-rendering-v1": "*",
    "fabric-screen-api-v1": "*"
  },
  "recommends": {
    "yet_another_config_lib_v3": ">=${yacl_version_fabric}"
  },
  "suggests": {
    "modmenu": ">=${mod_menu_version}-"
  },
  "custom": {
    "modmenu:clientsideOnly": true
  }
}